{
  "info": {
    "name": "Marketplace API — Payment",
    "_postman_id": "marketplace-api-v2-07-payment",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
