        {
          "name": "Verify Email",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/email/verify?id=1&hash=HASH&expires=EXPIRY&signature=SIG",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "email",
                "verify"
              ],
              "query": [
                {
                  "key": "id",
                  "value": "1"
                },
                {
                  "key": "hash",
                  "value": "HASH",
                  "description": "sha1(email)"
                },
                {
                  "key": "expires",
                  "value": "EXPIRY",
                  "description": "Unix timestamp"
                },
                {
                  "key": "signature",
                  "value": "SIG",
                  "description": "Laravel signed URL signature"
                }
              ]
            },
            "description": "Verifikasi email menggunakan signed URL yang dikirim via email.\n\n⚠️ URL ini di-generate otomatis oleh backend dan dikirim ke email user saat register.\n⚠️ URL valid selama 60 menit.\n⚠️ Tidak membutuhkan Bearer token."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"success\": true,\n  \"message\": \"Email verified successfully.\",\n  \"data\": null,\n  \"meta\": { \"timestamp\": \"2026-05-04T00:00:00.000000Z\" }\n}"
            },
            {
              "name": "403 Invalid Signature",
              "status": "Forbidden",
              "code": 403,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"success\": false,\n  \"message\": \"Invalid or expired verification link.\",\n  \"meta\": { \"timestamp\": \"2026-05-04T00:00:00.000000Z\" }\n}"
            },
            {
              "name": "422 Wrong Hash",
              "status": "Unprocessable Content",
              "code": 422,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"success\": false,\n  \"message\": \"Email verification failed.\",\n  \"meta\": { \"timestamp\": \"2026-05-04T00:00:00.000000Z\" }\n}"
            }
          ]
        },
