{
  "info": {
    "name": "Marketplace API — Auth",
    "_postman_id": "marketplace-api-v2-01-auth",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "refresh_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "01. Auth",
      "description": "Authentication — Register, Login, OAuth, Token Refresh, Logout, Email Verification, Password Reset, Session Management",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  if (body.data && body.data.access_token) {",
                  "    pm.collectionVariables.set('access_token', body.data.access_token);",
                  "  }",
                  "  if (body.data && body.data.refresh_token) {",
                  "    pm.collectionVariables.set('refresh_token', body.data.refresh_token);",
                  "  }",
                  "  pm.test('Register returns 201', () => pm.response.to.have.status(201));",
                  "  pm.test('Response has access_token', () => pm.expect(body.data).to.have.property('access_token'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "description": "Daftarkan user baru. Access token dan refresh token otomatis tersimpan ke collection variables."
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"success\": true,\n  \"message\": \"User registered successfully.\",\n  \"data\": {\n    \"user\": { \"id\": 1, \"name\": \"Test User\", \"email\": \"test@example.com\", \"avatar\": null, \"email_verified_at\": null },\n    \"access_token\": \"1|abc...\",\n    \"refresh_token\": \"def...\",\n    \"token_type\": \"Bearer\",\n    \"expires_in\": 3600,\n    \"provider\": \"password\"\n  },\n  \"meta\": { \"timestamp\": \"2026-05-04T00:00:00.000000Z\" }\n}"
            },
            {
              "name": "422 Validation Error",
              "status": "Unprocessable Content",
              "code": 422,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"success\": false,\n  \"message\": \"The given data was invalid.\",\n  \"errors\": { \"email\": [\"The email has already been taken.\"] },\n  \"meta\": { \"timestamp\": \"2026-05-04T00:00:00.000000Z\" }\n}"
            }
          ]
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
