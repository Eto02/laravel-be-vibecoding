                  "    pm.collectionVariables.set('access_token', body.data.access_token);",
                  "  }",
                  "  if (body.data && body.data.refresh_token) {",
                  "    pm.collectionVariables.set('refresh_token', body.data.refresh_token);",
                  "  }",
                  "  pm.test('Login returns 200', () => pm.response.to.have.status(200));",
                  "  pm.test('Response has access_token', () => pm.expect(body.data).to.have.property('access_token'));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Login dan dapatkan Sanctum access token + refresh token."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"success\": true,\n  \"message\": \"Login successful.\",\n  \"data\": {\n    \"user\": { \"id\": 1, \"name\": \"Test User\", \"email\": \"test@example.com\", \"avatar\": null, \"email_verified_at\": null },\n    \"access_token\": \"1|abc...\",\n    \"refresh_token\": \"def...\",\n    \"token_type\": \"Bearer\",\n    \"expires_in\": 3600,\n    \"provider\": \"password\"\n  },\n  \"meta\": { \"timestamp\": \"2026-05-04T00:00:00.000000Z\" }\n}"
            },
            {
              "name": "401 Invalid Credentials",
              "status": "Unauthorized",
              "code": 401,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"success\": false,\n  \"message\": \"Invalid credentials.\",\n  \"meta\": { \"timestamp\": \"2026-05-04T00:00:00.000000Z\" }\n}"
            }
          ]
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  if (body.data && body.data.access_token) {",
                  "    pm.collectionVariables.set('access_token', body.data.access_token);",
                  "  }",
                  "  if (body.data && body.data.refresh_token) {",
                  "    pm.collectionVariables.set('refresh_token', body.data.refresh_token);",
                  "  }",
                  "  pm.test('Refresh returns 200', () => pm.response.to.have.status(200));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/refresh",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "auth",
                "refresh"
              ]
            },
            "description": "Rotasi refresh token. Token lama diinvalidasi, pair baru di-return.\n\n⚠️ Tidak membutuhkan Bearer token — gunakan refresh_token di body."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"success\": true,\n  \"message\": \"Token refreshed successfully.\",\n  \"data\": {\n    \"user\": { \"id\": 1, \"name\": \"Test User\", \"email\": \"test@example.com\", \"avatar\": null, \"email_verified_at\": null },\n    \"access_token\": \"2|xyz...\",\n    \"refresh_token\": \"ghi...\",\n    \"token_type\": \"Bearer\",\n    \"expires_in\": 3600,\n    \"provider\": \"refresh\"\n  },\n  \"meta\": { \"timestamp\": \"2026-05-04T00:00:00.000000Z\" }\n}"
            },
            {
              "name": "401 Invalid Refresh Token",
              "status": "Unauthorized",
              "code": 401,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"success\": false,\n  \"message\": \"Invalid or expired refresh token.\",\n  \"meta\": { \"timestamp\": \"2026-05-04T00:00:00.000000Z\" }\n}"
            }
          ]
        },
        {
          "name": "Me (Current User) 🔒",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/me",
