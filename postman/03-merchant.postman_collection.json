      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "refresh_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "store_slug",
      "value": "",
      "type": "string"
    },
    {
      "key": "kyc_upload_url",
      "value": "",
      "type": "string"
    },
    {
      "key": "kyc_key",
      "value": "",
      "type": "string"
    },
    {
      "key": "logo_upload_url",
      "value": "",
      "type": "string"
    },
    {
      "key": "logo_key",
      "value": "",
      "type": "string"
    },
    {
      "key": "banner_upload_url",
      "value": "",
