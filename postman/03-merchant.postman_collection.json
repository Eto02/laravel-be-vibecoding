  "item": [
    {
      "name": "04. Merchant",
      "description": "Merchant & Store module — Store registration, profile management, KYC upload, followers, and public store views.",
      "item": [
        {
          "name": "Register Store 🔒",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  var json = pm.response.json();",
                  "  pm.collectionVariables.set(\"store_slug\", json.data.slug);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Toko Saya\",\n  \"description\": \"Toko terbaik di kota\",\n  \"city\": \"Bandung\",\n  \"province\": \"Jawa Barat\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/merchant/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "merchant",
                "register"
              ]
            }
          }
        },
