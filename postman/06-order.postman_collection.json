            },
            {
              "name": "[PUT] Merchant — Ship Order + AWB (processing→shipped) 🔒🏪",
              "request": {
                "auth": {
                  "type": "bearer",
                  "bearer": [
                    {
                      "key": "token",
                      "value": "{{access_token}}",
                      "type": "string"
                    }
