                  {
                    "key": "Accept",
                    "value": "application/json"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/api/orders/{{order_id}}",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "api",
                    "orders",
                    "{{order_id}}"
                  ]
                },
                "description": "Get order detail. IDOR protected — only returns own orders."
              },
              "response": [],
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                      "pm.test(\"Has items and status_logs\", () => {",
                      "    const j = pm.response.json();",
                      "    pm.expect(j.data).to.have.property(\"items\");",
                      "    pm.expect(j.data).to.have.property(\"status_logs\");",
