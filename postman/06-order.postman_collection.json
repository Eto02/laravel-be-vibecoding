      "item": [
        {
          "name": "Buyer",
          "item": [
            {
              "name": "[POST] Checkout 🔒",
              "request": {
                "auth": {
                  "type": "bearer",
                  "bearer": [
                    {
                      "key": "token",
                      "value": "{{access_token}}",
                      "type": "string"
                    }
                  ]
                },
                "method": "POST",
                "header": [
                  {
                    "key": "Accept",
                    "value": "application/json"
                  },
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  },
                  {
                    "key": "X-Idempotency-Key",
                    "value": "{{idempotency_key}}"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/api/orders/checkout",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "api",
                    "orders",
                    "checkout"
                  ]
                },
                "description": "Checkout cart. Requires X-Idempotency-Key header (min 8 chars, e.g. UUID). Creates one Order per store in cart. Decrements stock atomically inside DB transaction.",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"items\": [\n    {\n      \"store_id\": \"{{store_id}}\",\n      \"address_id\": \"{{address_id}}\",\n      \"shipping_courier\": \"jne\",\n      \"shipping_service\": \"REG\",\n      \"shipping_fee\": 1500000,\n      \"notes\": \"Tolong bubble wrap\"\n    }\n  ],\n  \"voucher_code\": null\n}",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
                }
              },
              "response": [
                {
                  "name": "201 — Checkout Successful",
                  "originalRequest": {},
                  "status": "Created",
                  "code": 201,
                  "_postman_previewlanguage": "json",
                  "body": "{\n  \"success\": true,\n  \"message\": \"Checkout successful.\",\n  \"data\": [\n    {\n      \"id\": 1,\n      \"order_number\": \"INV/2026/05/000001\",\n      \"status\": \"pending\",\n      \"status_label\": \"Menunggu Pembayaran\",\n      \"store\": {\n        \"id\": 1,\n        \"name\": \"Toko Demo\",\n        \"slug\": \"toko-demo\"\n      },\n      \"subtotal_cents\": 39000000,\n      \"subtotal\": \"Rp 390.000\",\n      \"shipping_fee_cents\": 1500000,\n      \"shipping_fee\": \"Rp 15.000\",\n      \"discount_cents\": 0,\n      \"discount\": \"Rp 0\",\n      \"total_cents\": 40500000,\n      \"total\": \"Rp 405.000\",\n      \"payment_due_at\": \"2026-05-12T00:00:00Z\",\n      \"items\": [\n        {\n          \"id\": 1,\n          \"product_name\": \"Sepatu Lari Pro\",\n          \"variant_sku\": \"SKU-SLP-40\",\n          \"quantity\": 1,\n          \"unit_price_cents\": 39000000,\n          \"subtotal_cents\": 39000000\n        }\n      ]\n    }\n  ],\n  \"meta\": {\n    \"timestamp\": \"2026-05-11T10:00:00Z\"\n  }\n}"
                },
                {
                  "name": "422 — Insufficient Stock",
                  "originalRequest": {},
                  "status": "Unprocessable Entity",
                  "code": 422,
                  "_postman_previewlanguage": "json",
                  "body": "{\n  \"success\": false,\n  \"message\": \"Insufficient stock for Sepatu Lari Pro. Please update your cart.\",\n  \"meta\": {\n    \"timestamp\": \"2026-05-11T10:00:00Z\"\n  }\n}"
                },
                {
                  "name": "422 — Missing Idempotency Key",
                  "originalRequest": {},
                  "status": "Unprocessable Entity",
                  "code": 422,
                  "_postman_previewlanguage": "json",
                  "body": "{\n  \"success\": false,\n  \"message\": \"The given data was invalid.\",\n  \"errors\": {\n    \"_idempotency_key\": [\n      \"The X-Idempotency-Key header is required.\"\n    ]\n  },\n  \"meta\": {\n    \"timestamp\": \"2026-05-11T10:00:00Z\"\n  }\n}"
                }
              ],
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Status 201\", () => pm.response.to.have.status(201));",
                      "pm.test(\"Has order data\", () => {",
                      "    const j = pm.response.json();",
                      "    pm.expect(j.data).to.be.an(\"array\");",
                      "    if (j.data && j.data[0]) {",
                      "        pm.collectionVariables.set(\"order_id\", j.data[0].id);",
                      "    }",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            },
