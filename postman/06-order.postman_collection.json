            {
              "name": "[POST] Cancel Order 🔒",
              "request": {
                "auth": {
                  "type": "bearer",
                  "bearer": [
                    {
                      "key": "token",
                      "value": "{{access_token}}",
                      "type": "string"
                    }
                  ]
                },
                "method": "POST",
                "header": [
                  {
                    "key": "Accept",
                    "value": "application/json"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/api/orders/{{order_id}}/cancel",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "api",
                    "orders",
                    "{{order_id}}",
                    "cancel"
                  ]
                },
                "description": "Cancel a pending order. Only allowed when status = pending. Restores stock via OrderCancelled event."
              },
              "response": [
                {
                  "name": "200 — Cancelled",
                  "originalRequest": {},
                  "status": "OK",
                  "code": 200,
                  "_postman_previewlanguage": "json",
                  "body": "{\n  \"success\": true,\n  \"message\": \"Order cancelled.\",\n  \"data\": {\n    \"id\": 1,\n    \"order_number\": \"INV/2026/05/000001\",\n    \"status\": \"cancelled\",\n    \"status_label\": \"Dibatalkan\"\n  },\n  \"meta\": {\n    \"timestamp\": \"2026-05-11T10:00:00Z\"\n  }\n}"
                },
                {
                  "name": "422 — Cannot Cancel (Already Paid)",
                  "originalRequest": {},
                  "status": "Unprocessable Entity",
                  "code": 422,
                  "_postman_previewlanguage": "json",
                  "body": "{\n  \"success\": false,\n  \"message\": \"Only pending orders can be cancelled.\",\n  \"meta\": {\n    \"timestamp\": \"2026-05-11T10:00:00Z\"\n  }\n}"
                }
              ],
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                      "pm.test(\"Status is cancelled\", () => {",
                      "    pm.expect(pm.response.json().data.status).to.eql(\"cancelled\");",
                      "});"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            },
            {
              "name": "[POST] Confirm Received (shipped→delivered) 🔒",
              "request": {
                "auth": {
                  "type": "bearer",
                  "bearer": [
                    {
                      "key": "token",
                      "value": "{{access_token}}",
                      "type": "string"
                    }
                  ]
                },
                "method": "POST",
                "header": [
                  {
                    "key": "Accept",
                    "value": "application/json"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/api/orders/{{order_id}}/receive",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "api",
                    "orders",
                    "{{order_id}}",
                    "receive"
                  ]
                },
                "description": "Buyer confirms package received. Transitions order shipped → delivered."
              },
              "response": [],
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                      "pm.test(\"Status is delivered\", () => pm.expect(pm.response.json().data.status).to.eql(\"delivered\"));"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            },
            {
              "name": "[POST] File Dispute 🔒",
              "request": {
                "auth": {
                  "type": "bearer",
                  "bearer": [
                    {
                      "key": "token",
                      "value": "{{access_token}}",
                      "type": "string"
                    }
                  ]
                },
                "method": "POST",
                "header": [
                  {
                    "key": "Accept",
                    "value": "application/json"
                  },
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/api/orders/{{order_id}}/disputes",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "api",
                    "orders",
                    "{{order_id}}",
                    "disputes"
                  ]
                },
                "description": "File a dispute on a shipped/delivered/completed order. Changes order status to disputed.",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"reason\": \"Item not as described\",\n  \"description\": \"The product received is completely different from the listing photo and description provided by the seller.\"\n}",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
                }
              },
              "response": [
                {
                  "name": "201 — Dispute Created",
                  "originalRequest": {},
                  "status": "Created",
                  "code": 201,
                  "_postman_previewlanguage": "json",
                  "body": "{\n  \"success\": true,\n  \"message\": \"Dispute submitted.\",\n  \"data\": {\n    \"id\": 1,\n    \"reason\": \"Item not as described\",\n    \"description\": \"The product received is...\",\n    \"status\": \"open\",\n    \"resolution\": null,\n    \"created_at\": \"2026-05-11T10:00:00Z\"\n  },\n  \"meta\": {\n    \"timestamp\": \"2026-05-11T10:00:00Z\"\n  }\n}"
                },
                {
                  "name": "422 — Wrong Status",
                  "originalRequest": {},
                  "status": "Unprocessable Entity",
                  "code": 422,
                  "_postman_previewlanguage": "json",
                  "body": "{\n  \"success\": false,\n  \"message\": \"Disputes can only be filed for shipped, delivered, or completed orders.\",\n  \"meta\": {\n    \"timestamp\": \"2026-05-11T10:00:00Z\"\n  }\n}"
                }
              ],
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "pm.test(\"Status 201\", () => pm.response.to.have.status(201));",
                      "pm.test(\"Dispute status is open\", () => pm.expect(pm.response.json().data.status).to.eql(\"open\"));"
                    ],
                    "type": "text/javascript"
                  }
                }
              ]
            }
          ]
        },
