                    "value": "application/json"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/api/merchant/orders/{{order_id}}/ship",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "api",
                    "merchant",
                    "orders",
                    "{{order_id}}",
                    "ship"
                  ]
