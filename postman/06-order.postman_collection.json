                "description": "Merchant inputs AWB (tracking number). Transitions processing → shipped. Triggers OrderShipped event → sends shipping notification email to buyer.",
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"tracking_number\": \"{{tracking_number}}\"\n}",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
                }
