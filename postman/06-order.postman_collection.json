              "response": [
                {
                  "name": "200 — Shipped",
                  "originalRequest": {},
                  "status": "OK",
                  "code": 200,
                  "_postman_previewlanguage": "json",
                  "body": "{\n  \"success\": true,\n  \"message\": \"Order marked as shipped.\",\n  \"data\": {\n    \"id\": 1,\n    \"status\": \"shipped\",\n    \"status_label\": \"Dikirim\",\n    \"tracking_number\": \"JNE20260511001\"\n  },\n  \"meta\": {\n    \"timestamp\": \"2026-05-11T10:00:00Z\"\n  }\n}"
                },
                {
                  "name": "422 — Missing Tracking Number",
                  "originalRequest": {},
                  "status": "Unprocessable Entity",
                  "code": 422,
                  "_postman_previewlanguage": "json",
                  "body": "{\n  \"success\": false,\n  \"message\": \"The given data was invalid.\",\n  \"errors\": {\n    \"tracking_number\": [\n      \"The tracking number field is required.\"\n    ]\n  },\n  \"meta\": {\n    \"timestamp\": \"2026-05-11T10:00:00Z\"\n  }\n}"
                }
              ],
              "event": [
                {
                  "listen": "test",
                  "script": {
