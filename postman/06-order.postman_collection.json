                  }
                ],
                "url": {
                  "raw": "{{base_url}}/api/merchant/orders/{{order_id}}/confirm",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "api",
                    "merchant",
                    "orders",
                    "{{order_id}}",
                    "confirm"
                  ]
                },
                "description": "Merchant confirms order. Transitions paid → processing. Only works when order status is paid."
              },
              "response": [
                {
                  "name": "200 — Confirmed",
                  "originalRequest": {},
                  "status": "OK",
                  "code": 200,
                  "_postman_previewlanguage": "json",
                  "body": "{\n  \"success\": true,\n  \"message\": \"Order confirmed.\",\n  \"data\": {\n    \"id\": 1,\n    \"status\": \"processing\",\n    \"status_label\": \"Diproses\"\n  },\n  \"meta\": {\n    \"timestamp\": \"2026-05-11T10:00:00Z\"\n  }\n}"
                },
