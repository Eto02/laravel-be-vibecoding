{
  "info": {
    "name": "Marketplace API — Payment Webhooks",
    "_postman_id": "marketplace-api-v2-07-webhooks",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "noauth"
  },
  "variable": [
    { "key": "base_url",    "value": "http://localhost:8000", "type": "string" },
    { "key": "access_token","value": "",                      "type": "string" },
    { "key": "refresh_token","value": "",                     "type": "string" }
  ],
  "item": [
    {
      "name": "Webhooks",
      "description": "Webhook endpoints — public, no Bearer auth. Verified via gateway signature.",
      "item": [
        {
          "name": "Xendit — VA Paid",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Webhook returns 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Accept",          "value": "application/json" },
              { "key": "Content-Type",    "value": "application/json" },
              { "key": "x-callback-token","value": "{{XENDIT_WEBHOOK_TOKEN}}", "description": "From .env XENDIT_WEBHOOK_TOKEN" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"62efe2def7d34a54e6a51c81\",\n  \"event\": \"virtual_account.payment.created\",\n  \"payment_id\": \"pay-xxx\",\n  \"external_id\": \"PAY-ABCDEFGHIJ-5\",\n  \"account_number\": \"8808123456789\",\n  \"bank_code\": \"BCA\",\n  \"amount\": 39000000,\n  \"currency\": \"IDR\",\n  \"payment_detail\": { \"source\": \"VA\" }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/webhooks/xendit",
              "host": ["{{base_url}}"],
              "path": ["api", "webhooks", "xendit"]
            },
            "description": "Xendit Virtual Account payment webhook.\n\n⚠️ Endpoint ini PUBLIC — tidak butuh Bearer token.\n⚠️ Verifikasi via `x-callback-token` header (compare to env `XENDIT_WEBHOOK_TOKEN`).\n\n`external_id` harus match dengan `payments.gateway_ref` atau `transactions.external_id`.\n\nWebhook idempotent — jika payment sudah `paid` atau `refunded`, event diabaikan."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{ \"message\": \"Webhook processed.\" }"
            },
            {
              "name": "403 Forbidden — Invalid Signature",
              "status": "Forbidden",
              "code": 403,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"success\": false,\n  \"message\": \"Invalid webhook signature.\",\n  \"meta\": { \"timestamp\": \"2026-05-12T10:00:00.000000Z\" }\n}"
            }
          ]
        },
        {
          "name": "Xendit — QRIS Paid",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Accept",          "value": "application/json" },
              { "key": "Content-Type",    "value": "application/json" },
              { "key": "x-callback-token","value": "{{XENDIT_WEBHOOK_TOKEN}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"qr-xxx\",\n  \"event\": \"qr_code.payment.succeeded\",\n  \"reference_id\": \"PAY-ABCDEFGHIJ-6\",\n  \"amount\": 50000000,\n  \"currency\": \"IDR\",\n  \"charge_status\": \"SUCCEEDED\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/webhooks/xendit",
              "host": ["{{base_url}}"],
              "path": ["api", "webhooks", "xendit"]
            },
            "description": "Xendit QRIS payment webhook.\n\n`reference_id` maps to `external_id` in payment/transaction records."
          }
        },
        {
          "name": "Xendit — E-wallet Paid",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Accept",          "value": "application/json" },
              { "key": "Content-Type",    "value": "application/json" },
              { "key": "x-callback-token","value": "{{XENDIT_WEBHOOK_TOKEN}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event\": \"ewallet.payment\",\n  \"business_id\": \"xxx\",\n  \"created\": \"2026-05-12T10:00:00.000Z\",\n  \"data\": {\n    \"id\": \"ewc-xxx\",\n    \"reference_id\": \"PAY-ABCDEFGHIJ-7\",\n    \"status\": \"SUCCEEDED\",\n    \"currency\": \"IDR\",\n    \"charge_amount\": 100000000,\n    \"capture_amount\": 100000000,\n    \"checkout_method\": \"ONE_TIME_PAYMENT\",\n    \"channel_code\": \"GOPAY\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/webhooks/xendit",
              "host": ["{{base_url}}"],
              "path": ["api", "webhooks", "xendit"]
            },
            "description": "Xendit e-wallet payment webhook (GoPay/DANA/ShopeePay/OVO/LinkAja)."
          }
        },
        {
          "name": "Midtrans — Settlement",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Midtrans webhook returns 200', () => pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Accept",       "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transaction_time\": \"2026-05-12 10:00:00\",\n  \"transaction_status\": \"settlement\",\n  \"transaction_id\": \"xxx\",\n  \"status_message\": \"midtrans payment notification\",\n  \"status_code\": \"200\",\n  \"signature_key\": \"compute_sha512_of(order_id + status_code + gross_amount + server_key)\",\n  \"payment_type\": \"bank_transfer\",\n  \"order_id\": \"PAY-ABCDEFGHIJ-8\",\n  \"merchant_id\": \"xxx\",\n  \"gross_amount\": \"100000.00\",\n  \"fraud_status\": \"accept\",\n  \"currency\": \"IDR\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/webhooks/midtrans",
              "host": ["{{base_url}}"],
              "path": ["api", "webhooks", "midtrans"]
            },
            "description": "Midtrans payment notification webhook (Snap).\n\n⚠️ Endpoint ini PUBLIC — tidak butuh Bearer token.\n⚠️ Signature verification: `SHA-512(order_id + status_code + gross_amount + serverKey)` dibandingkan dengan `signature_key` di payload.\n\n**transaction_status mappings:**\n- `settlement` → `paid`\n- `capture` + `fraud_status: accept` → `paid`\n- `deny` → `failed`\n- `cancel` / `expire` → `expired`\n\n`order_id` dalam payload Midtrans = `external_id` dalam transactions table."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{ \"message\": \"Webhook processed.\" }"
            }
          ]
        }
      ]
    }
  ]
}
